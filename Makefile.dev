# ============================================================================
# ANPR LOCAL DEVELOPMENT MAKEFILE
# Quick commands for day-to-day development
#
# Key targets:
#   make dev-setup    Install & start everything (first-time only)
#   make dev-up       Start docker-compose stack
#   make dev-down     Stop docker-compose stack
#   make dev-init     Initialize database (migrations + seeding)
#   make dev-logs     Follow service logs
#   make test         Run all tests (unit + integration)
#   make clean        Remove caches and temporary files
# ============================================================================

.PHONY: help dev-setup dev-up dev-down dev-init dev-logs dev-reset \
        test test-unit test-int test-watch lint fmt clean \
        db-seed db-migrate api worker redis-cli psql

PYTHON ?= python
UV ?= uv
COMPOSE ?= docker compose
ENV_FILE ?= .env.local

# Colors for output
BLUE := \033[0;34m
GREEN := \033[0;32m
RED := \033[0;31m
RESET := \033[0m

help:
	@echo "$(BLUE)ANPR Local Development$(RESET)"
	@echo ""
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | \
		awk 'BEGIN {FS = ":.*?## "}; {printf "  $(BLUE)%-20s$(RESET) %s\n", $$1, $$2}' | sort
	@echo ""
	@echo "$(BLUE)Quick Start:$(RESET)"
	@echo "  1. make dev-setup          (one-time setup)"
	@echo "  2. make dev-up             (start services)"
	@echo "  3. make test               (verify everything works)"

# ============================================================================
# SETUP & INFRASTRUCTURE
# ============================================================================

dev-setup: ## [FIRST TIME] Install deps, generate secrets, start services
	@echo "$(GREEN)Setting up ANPR development environment...$(RESET)"
	@echo ""
	@echo "Step 1/3: Installing Python dependencies..."
	$(UV) sync
	@echo "$(GREEN)✓ Dependencies installed$(RESET)"
	@echo ""
	@echo "Step 2/3: Generating secrets..."
	@if [ ! -f $(ENV_FILE) ]; then \
		echo "$(BLUE)Generating JWT_SECRET...$(RESET)"; \
		JWT_SECRET=$$($(PYTHON) -c "import secrets; print(secrets.token_urlsafe(32))"); \
		echo "$(BLUE)Generating FERNET_KEY...$(RESET)"; \
		FERNET_KEY=$$($(PYTHON) -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"); \
		CELERY_KEY=$$($(PYTHON) -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"); \
		cp .env.local.example $(ENV_FILE); \
		echo "$(BLUE)Created $(ENV_FILE) with generated secrets$(RESET)"; \
		echo "  JWT_SECRET=$$JWT_SECRET"; \
		echo "  FERNET_KEY=$$FERNET_KEY"; \
		echo "  CELERY_ENCRYPTION_KEY=$$CELERY_KEY"; \
	else \
		echo "$(GREEN)$(ENV_FILE) already exists, skipping...$(RESET)"; \
	fi
	@echo "$(GREEN)✓ Secrets ready$(RESET)"
	@echo ""
	@echo "Step 3/3: Starting docker-compose services..."
	$(COMPOSE) up -d --wait
	@echo "$(GREEN)✓ Services running$(RESET)"
	@echo ""
	@echo "$(BLUE)Initializing database...$(RESET)"
	$(PYTHON) scripts/init_dev_env.py
	@echo ""
	@echo "$(GREEN)✓ Development environment ready!$(RESET)"
	@echo ""
	@echo "$(BLUE)Next steps:$(RESET)"
	@echo "  • Run tests:     make test"
	@echo "  • View API docs: open http://localhost:8000/docs"
	@echo "  • Check logs:    make dev-logs"

dev-up: ## Start docker-compose services (postgres, redis, minio, api, worker)
	@echo "$(BLUE)Starting services...$(RESET)"
	$(COMPOSE) up -d --wait
	@echo "$(GREEN)✓ Services started$(RESET)"
	@echo ""
	@echo "Available endpoints:"
	@echo "  API:             $(BLUE)http://localhost:8000$(RESET)"
	@echo "  API Docs:        $(BLUE)http://localhost:8000/docs$(RESET)"
	@echo "  pgAdmin:         $(BLUE)http://localhost:5050$(RESET)"
	@echo "  Redis Commander: $(BLUE)http://localhost:8081$(RESET)"
	@echo "  MinIO Console:   $(BLUE)http://localhost:9001$(RESET)"

dev-down: ## Stop all docker-compose services
	@echo "$(BLUE)Stopping services...$(RESET)"
	$(COMPOSE) down
	@echo "$(GREEN)✓ Services stopped$(RESET)"

dev-init: ## Initialize database (run migrations + seed data)
	@echo "$(BLUE)Initializing database...$(RESET)"
	$(PYTHON) scripts/init_dev_env.py

dev-reset: ## [DESTRUCTIVE] Drop all tables and reinitialize from scratch
	@echo "$(RED)⚠ WARNING: This will delete all local data!$(RESET)"
	@read -p "Continue? [y/N] " -n 1 -r; \
	echo ""; \
	if [[ $$REPLY =~ ^[Yy]$$ ]]; then \
		$(PYTHON) scripts/init_dev_env.py --reset; \
	else \
		echo "$(BLUE)Cancelled$(RESET)"; \
	fi

dev-logs: ## Follow service logs (api, worker, postgres, redis)
	@echo "$(BLUE)Tailing logs... (Ctrl+C to exit)$(RESET)"
	$(COMPOSE) logs -f --tail=100

dev-logs-api: ## Follow API logs only
	$(COMPOSE) logs -f api --tail=50

dev-logs-worker: ## Follow Celery worker logs
	$(COMPOSE) logs -f worker --tail=50

# ============================================================================
# DATABASE & MIGRATIONS
# ============================================================================

db-migrate: ## Run Alembic migrations (upgrade to head)
	@echo "$(BLUE)Running migrations...$(RESET)"
	$(PYTHON) -m alembic -c db/alembic.ini upgrade head
	@echo "$(GREEN)✓ Migrations complete$(RESET)"

db-seed: ## Seed database with test data
	@echo "$(BLUE)Seeding database...$(RESET)"
	$(PYTHON) seed_db.py

db-status: ## Show current Alembic migration status
	$(PYTHON) -m alembic -c db/alembic.ini current

psql: ## Connect to PostgreSQL interactively (docker-compose must be running)
	$(COMPOSE) exec postgres psql -U anpr -d anpr_db

redis-cli: ## Connect to Redis interactively
	$(COMPOSE) exec redis redis-cli

# ============================================================================
# TESTING
# ============================================================================

test: test-unit test-int ## Run all tests (unit + integration)

test-unit: ## Run unit tests only
	@echo "$(BLUE)Running unit tests...$(RESET)"
	$(PYTHON) -m pytest tests/unit -v --tb=short

test-int: ## Run integration tests only
	@echo "$(BLUE)Running integration tests...$(RESET)"
	$(PYTHON) -m pytest tests/integration -v --tb=short

test-watch: ## Run tests in watch mode (reruns on file changes)
	$(PYTHON) -m pytest tests/ -v --tb=short -k "not slow" \
		--looponfail --maxfail=1

test-cov: ## Run tests with coverage report
	@echo "$(BLUE)Running tests with coverage...$(RESET)"
	$(PYTHON) -m pytest tests/ --cov=api --cov=db --cov=workers \
		--cov=anpr_core --cov-report=term-missing --cov-report=html
	@echo "$(GREEN)✓ Coverage report: $(RESET)htmlcov/index.html"

test-specific: ## Run a specific test: make test-specific FILE=tests/unit/test_auth.py
	@if [ -z "$(FILE)" ]; then \
		echo "$(RED)Error: specify FILE=tests/unit/test_*.py$(RESET)"; \
		exit 1; \
	fi
	$(PYTHON) -m pytest $(FILE) -v --tb=short

test-slow: ## Run slow tests (includes GPU tests)
	$(PYTHON) -m pytest tests/ -v -m slow --tb=short

# ============================================================================
# CODE QUALITY
# ============================================================================

lint: ## Check code with ruff + mypy
	@echo "$(BLUE)Linting with ruff...$(RESET)"
	uv run ruff check .
	@echo "$(GREEN)✓ Ruff passed$(RESET)"
	@echo ""
	@echo "$(BLUE)Type checking with mypy...$(RESET)"
	uv run mypy anpr_core api ingest workers db
	@echo "$(GREEN)✓ Mypy passed$(RESET)"

fmt: ## Format code with ruff
	@echo "$(BLUE)Formatting code...$(RESET)"
	uv run ruff format .
	uv run ruff check --fix .
	@echo "$(GREEN)✓ Formatting complete$(RESET)"

fmt-check: ## Check code formatting without changing files
	uv run ruff format --check .
	uv run ruff check .

# ============================================================================
# UTILITIES
# ============================================================================

pip-list: ## List installed dependencies
	$(PYTHON) -m pip list

pip-freeze: ## Show requirements.txt-compatible output
	$(PYTHON) -m pip freeze | grep -E "^(fastapi|sqlalchemy|celery|redis|opencv|ultralytics|paddleocr)" || true

docker-logs: ## Show raw docker-compose logs (unfollow)
	$(COMPOSE) logs --tail=50

docker-ps: ## Show running containers
	$(COMPOSE) ps

docker-restart: ## Restart all services
	@echo "$(BLUE)Restarting services...$(RESET)"
	$(COMPOSE) restart
	@echo "$(GREEN)✓ Services restarted$(RESET)"

docker-clean: ## Remove containers (keeps volumes)
	@echo "$(RED)Removing containers...$(RESET)"
	$(COMPOSE) down
	@echo "$(GREEN)✓ Containers removed (data persisted)$(RESET)"

docker-nuke: ## [DESTRUCTIVE] Remove containers AND volumes
	@echo "$(RED)⚠ WARNING: This will delete all local volumes!$(RESET)"
	@read -p "Continue? [y/N] " -n 1 -r; \
	echo ""; \
	if [[ $$REPLY =~ ^[Yy]$$ ]]; then \
		$(COMPOSE) down -v; \
		echo "$(GREEN)✓ Containers and volumes removed$(RESET)"; \
	else \
		echo "$(BLUE)Cancelled$(RESET)"; \
	fi

clean: ## Remove Python caches, test artifacts, and coverage
	@echo "$(BLUE)Cleaning Python caches...$(RESET)"
	find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
	find . -type f -name "*.pyc" -delete 2>/dev/null || true
	rm -rf .pytest_cache .mypy_cache .ruff_cache .coverage htmlcov
	rm -rf .code-review-graph
	@echo "$(GREEN)✓ Cleaned$(RESET)"

install: ## Install all dependencies (including dev deps)
	$(UV) sync

# ============================================================================
# DEVELOPMENT WORKFLOWS
# ============================================================================

# Example: make dev-loop WATCH=api/routers/auth.py
# (useful for TDD workflow)

docs: ## View FastAPI OpenAPI docs
	@echo "$(BLUE)Opening API documentation...$(RESET)"
	@python -m webbrowser "http://localhost:8000/docs"

bench: ## Run accuracy + latency benchmark on golden sets
	@echo "$(BLUE)Running benchmarks...$(RESET)"
	$(PYTHON) benchmarks/eval.py --set golden_in_small
	@echo "$(GREEN)✓ Benchmarks complete$(RESET)"

demo-webcam: ## Run live plate detection from laptop camera
	$(PYTHON) -m scripts.demo --source webcam

demo-iphone: ## Run live plate detection from iPhone camera (Continuity)
	$(PYTHON) -m scripts.demo --source iphone

health: ## Check health of all services
	@echo "$(BLUE)Checking service health...$(RESET)"
	@echo "API:        $$(curl -s http://localhost:8000/healthz | grep -q 'ok' && echo '$(GREEN)✓$(RESET)' || echo '$(RED)✗$(RESET)')"
	@echo "Postgres:   $$($(COMPOSE) exec -T postgres pg_isready -U postgres >/dev/null 2>&1 && echo '$(GREEN)✓$(RESET)' || echo '$(RED)✗$(RESET)')"
	@echo "Redis:      $$($(COMPOSE) exec -T redis redis-cli ping | grep -q 'PONG' && echo '$(GREEN)✓$(RESET)' || echo '$(RED)✗$(RESET)')"

.PHONY: help
