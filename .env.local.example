# ============================================================================
# LOCAL DEVELOPMENT ENVIRONMENT
# Copy this to .env.local and fill in actual secrets below.
# This file is git-ignored and should never be committed.
#
# SECURITY: All placeholder values below must be replaced with actual secrets
# before running the application. Generate secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# DO NOT commit actual secrets to version control.
# ============================================================================

# ---- App Configuration ----
ANPR_ENV=dev
LOG_LEVEL=DEBUG
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
API_TITLE=ANPR Backend API (Dev)
API_VERSION=0.1.0

# ---- Frontend CORS ----
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5050

# ---- Auth & Security ----
# CRITICAL: Generate a new secret for your local environment
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=<GENERATE_SECURE_JWT_SECRET_MIN_32_CHARS>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# ---- Encryption Keys (for Celery, local only) ----
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# These are used to encrypt sensitive data in transit. In production, use AWS Secrets Manager.
FERNET_KEY=<GENERATE_FERNET_KEY_BASE64>
CELERY_ENCRYPTION_KEY=<GENERATE_CELERY_ENCRYPTION_KEY_BASE64>

# ---- Database ----
# docker-compose.yml sets up postgres:16-alpine
# Connection string uses async PostgreSQL driver
# Replace PASSWORD_PLACEHOLDER with a secure password generated locally
DATABASE_URL=postgresql+asyncpg://anpr:<GENERATE_SECURE_DB_PASSWORD>@postgres:5432/anpr_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30

# ---- Redis ----
# docker-compose.yml sets up redis:7-alpine
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_BACKEND_URL=redis://redis:6379/1

# ---- MinIO / S3 (local S3-compatible storage) ----
# docker-compose.yml sets up MinIO at localhost:9000
# Access console at http://localhost:9001
# CRITICAL: Change default MinIO credentials in docker-compose.override.yml
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=<GENERATE_SECURE_MINIO_ACCESS_KEY>
S3_SECRET_KEY=<GENERATE_SECURE_MINIO_SECRET_KEY>
S3_REGION=us-east-1
S3_BUCKET_CROPS=anpr-crops
S3_BUCKET_FRAMES=anpr-frames
S3_BUCKET_AUDIT=anpr-audit

# MinIO admin credentials (for console access at http://localhost:9001)
# CRITICAL: Change these from defaults in docker-compose.override.yml
MINIO_ROOT_USER=<GENERATE_SECURE_MINIO_USER>
MINIO_ROOT_PASSWORD=<GENERATE_SECURE_MINIO_PASSWORD>

# ---- Pipeline Configuration ----
TARGET_FPS=15
CONFIDENCE_PLATE=0.75
CONFIDENCE_CHAR=0.60
TRACK_VOTE_WINDOW=8

# ---- Model Configuration ----
DETECTOR_WEIGHTS=models/plate_yolov8s.pt
OCR_BACKEND=paddle  # paddle | crnn | fusion
PADDLE_OCR_LANG=en

# ---- Ingest Sources (optional for local testing) ----
WEBCAM_INDEX=0
IPHONE_SOURCE=continuity
IPHONE_RTSP_URL=rtsp://192.168.0.50:8080/video
RTSP_RECONNECT_BACKOFF_SEC=2
RTSP_RECONNECT_MAX_SEC=60

# ---- Monitoring (optional) ----
PROMETHEUS_MULTIPROC_DIR=/tmp/prom-multi
OTEL_EXPORTER_OTLP_ENDPOINT=
GRAFANA_USER=admin
GRAFANA_PASSWORD=<GENERATE_SECURE_GRAFANA_PASSWORD>

# ---- MLflow (optional, for model tracking) ----
MLFLOW_TRACKING_URI=http://mlflow:5000

# ---- Alerts (optional) ----
ALERT_WEBHOOK_URL=
ALERT_DEDUP_WINDOW_SEC=300
