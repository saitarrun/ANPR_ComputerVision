# Copy to .env and fill in values from your secrets manager
# (AWS Secrets Manager, HashiCorp Vault, or 1Password)

# ---- App ----
ANPR_ENV=dev
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# ---- Auth + Security ----
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ---- Encryption (for Celery/Redis; dev only; use KMS in prod) ----
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CELERY_ENCRYPTION_KEY=
FERNET_KEY=

# ---- Postgres ----
POSTGRES_USER=anpr
POSTGRES_PASSWORD=
POSTGRES_DB=anpr
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://anpr:PASSWORD@localhost:5432/anpr

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- MinIO / S3 ----
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_BUCKET_CROPS=anpr-crops
S3_BUCKET_FRAMES=anpr-frames
S3_BUCKET_AUDIT=anpr-audit
MINIO_ROOT_USER=anpr_admin
MINIO_ROOT_PASSWORD=

# ---- Observability ----
PROMETHEUS_MULTIPROC_DIR=/tmp/prom-multi
OTEL_EXPORTER_OTLP_ENDPOINT=
GRAFANA_USER=admin
GRAFANA_PASSWORD=

# ---- Models ----
DETECTOR_WEIGHTS=models/plate_yolov8s.pt
OCR_BACKEND=paddle                # paddle | crnn | fusion
PADDLE_OCR_LANG=en
MLFLOW_TRACKING_URI=

# ---- Pipeline ----
TARGET_FPS=15
CONFIDENCE_PLATE=0.75
CONFIDENCE_CHAR=0.60
TRACK_VOTE_WINDOW=8

# ---- Ingest ----
WEBCAM_INDEX=0                    # 0 = laptop FaceTime cam
IPHONE_SOURCE=continuity          # continuity | rtsp
IPHONE_RTSP_URL=rtsp://192.168.0.50:8080/video
RTSP_RECONNECT_BACKOFF_SEC=2
RTSP_RECONNECT_MAX_SEC=60

# ---- Watchlist / alerts ----
ALERT_WEBHOOK_URL=
ALERT_DEDUP_WINDOW_SEC=300
