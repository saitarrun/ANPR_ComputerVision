# Copy to .env and edit. Never commit .env.

# ---- App ----
ANPR_ENV=dev
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# ---- Auth ----
JWT_SECRET=change-me-to-a-32+-byte-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ---- Encryption (dev only; use KMS in prod) ----
FERNET_KEY=                       # generate via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ---- Postgres ----
POSTGRES_USER=anpr
POSTGRES_PASSWORD=anpr_dev_pw
POSTGRES_DB=anpr
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://anpr:anpr_dev_pw@localhost:5432/anpr

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- MinIO / S3 ----
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=anpr_admin
S3_SECRET_KEY=anpr_dev_pw
S3_REGION=us-east-1
S3_BUCKET_CROPS=anpr-crops
S3_BUCKET_FRAMES=anpr-frames
S3_BUCKET_AUDIT=anpr-audit
MINIO_ROOT_USER=anpr_admin
MINIO_ROOT_PASSWORD=anpr_dev_pw

# ---- Observability ----
PROMETHEUS_MULTIPROC_DIR=/tmp/prom-multi
OTEL_EXPORTER_OTLP_ENDPOINT=
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ---- Models ----
DETECTOR_WEIGHTS=models/plate_yolov8s.pt
OCR_BACKEND=paddle                # paddle | crnn | fusion
PADDLE_OCR_LANG=en
MLFLOW_TRACKING_URI=

# ---- Pipeline ----
TARGET_FPS=15
CONFIDENCE_PLATE=0.75
CONFIDENCE_CHAR=0.60
TRACK_VOTE_WINDOW=8

# ---- Ingest ----
WEBCAM_INDEX=0                    # 0 = laptop FaceTime cam
IPHONE_SOURCE=continuity          # continuity | rtsp
IPHONE_RTSP_URL=rtsp://192.168.0.50:8080/video
RTSP_RECONNECT_BACKOFF_SEC=2
RTSP_RECONNECT_MAX_SEC=60

# ---- Watchlist / alerts ----
ALERT_WEBHOOK_URL=
ALERT_DEDUP_WINDOW_SEC=300
